{
  "name": "@bam.tech/stack-weekly",
  "version": "0.3.0",
  "description": "Weekly digest from This Week In React, filtered against your project's stack",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "stack-weekly": "bin/stack-weekly.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "build:scripts": "tsc -p tsconfig.scripts.json",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "prepare": "tsc",
    "prepublishOnly": "npm run build",
    "update-index": "npm run build:scripts && node dist/scripts/update-index.js"
  },
  "keywords": [
    "cli",
    "react",
    "react-native",
    "newsletter",
    "this-week-in-react",
    "package-json",
    "stack",
    "weekly"
  ],
  "author": "Eliott Gandiolle",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theodo-group/stack-weekly.git"
  },
  "bugs": {
    "url": "https://github.com/theodo-group/stack-weekly/issues"
  },
  "homepage": "https://github.com/theodo-group/stack-weekly#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ink": "^6.6.0",
    "ink-spinner": "^5.0.0",
    "node-html-parser": "^7.0.1",
    "react": "^19.2.3",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.9",
    "openai": "^4.77.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
